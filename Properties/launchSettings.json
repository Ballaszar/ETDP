{
  "profiles": {
    "http": {
      "commandName": "Project",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "AI_MODE": "offline",
        "OCR_ENGINE": "tesseract",
        "LOCAL_LLM_ENDPOINT": "http://127.0.0.1:5000/api/chat",
        "LOCAL_LLM_MODEL": "qwen2.5-coder:14b",
        "QWEN_ENABLED": "true",
        "QWEN_BASE_URL": "http://127.0.0.1:5000",
        "SMI_ENABLED": "true",
        "SMI_BASE_URL": "http://127.0.0.1:5000",
        "SMI_TIMEOUT_SECONDS": "4"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "http://localhost:5299"
    },
    "https": {
      "commandName": "Project",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "AI_MODE": "offline",
        "OCR_ENGINE": "tesseract",
        "LOCAL_LLM_ENDPOINT": "http://127.0.0.1:5000/api/chat",
        "LOCAL_LLM_MODEL": "qwen2.5-coder:14b",
        "QWEN_ENABLED": "true",
        "QWEN_BASE_URL": "http://127.0.0.1:5000",
        "SMI_ENABLED": "true",
        "SMI_BASE_URL": "http://127.0.0.1:5000",
        "SMI_TIMEOUT_SECONDS": "4"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7280;http://localhost:5299"
    },
    "IIS Express": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "AI_MODE": "offline",
        "OCR_ENGINE": "tesseract",
        "LOCAL_LLM_ENDPOINT": "http://127.0.0.1:5000/api/chat",
        "LOCAL_LLM_MODEL": "qwen2.5-coder:14b",
        "QWEN_ENABLED": "true",
        "QWEN_BASE_URL": "http://127.0.0.1:5000",
        "SMI_ENABLED": "true",
        "SMI_BASE_URL": "http://127.0.0.1:5000",
        "SMI_TIMEOUT_SECONDS": "4"
      }
    },
    "Container (Dockerfile)": {
      "commandName": "Docker",
      "launchBrowser": true,
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}/swagger",
      "environmentVariables": {
        "ASPNETCORE_HTTPS_PORTS": "8081",
        "ASPNETCORE_HTTP_PORTS": "8080"
      },
      "publishAllPorts": true,
      "useSSL": true
    }
  },
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:5299",
      "sslPort": 7280
    }
  }
}
